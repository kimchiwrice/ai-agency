# AI Agency — API Keys
# Copy this file to .env and fill in your keys
# NEVER commit .env to git (it's in .gitignore)

# Replicate — Image generation (Flux, SDXL, Kling models)
# Get your token: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your_token_here

# Kling AI — Video/image generation
# Get your key: https://kling.ai/dev (Go to Console → API Keys)
KLING_API_KEY=your_key_here

# Stability AI — Stable Diffusion image generation
# Get your key: https://platform.stability.ai/account/keys
STABILITY_API_KEY=your_key_here

# Anthropic — Claude AI (for GitHub Actions agent builds)
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_key_here
